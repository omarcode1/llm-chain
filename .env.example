# Server
PORT=3000

# Cursor (required for default LLM provider)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# Jira (required for ticket loading)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# LLM provider switch: cursor | bedrock
LLM_PROVIDER=cursor

# AWS Bedrock (optional — enable when ready)
BEDROCK_AWS_REGION=us-east-1
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v1

# Pinecone (optional — falls back to in-memory)
PINECONE_API_KEY=
PINECONE_INDEX=

# LangSmith (optional — for evaluation evidence)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=llmchain-pr-agent

# Default repo path for git diff / Cursor analysis
DEFAULT_REPO_PATH=.
